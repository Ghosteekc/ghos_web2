# Базовый URL backend API.
#
# Production (Vercel) — ваш рабочий вариант:
#   VITE_API_URL=https://ghosteekcr.loca.lt
# Браузер ходит на туннель напрямую; redeploy не нужен при перезапуске start-tunnel.ps1.
#
# Альтернатива: VITE_API_URL пустой, URL туннеля в webapp/vercel.json → rewrites → destination.
#
# Локальная разработка: пусто (Vite проксирует /api → localhost:8080) или:
#   VITE_API_URL=http://localhost:8080
VITE_API_URL=
